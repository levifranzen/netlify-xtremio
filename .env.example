# ── Signing secret for config tokens (generate with: openssl rand -hex 32)
TOKEN_SECRET=change-me-32-random-bytes-hex

# ── Admin panel password
ADMIN_SECRET=change-me-admin-password

# ── Upstash Redis (https://console.upstash.com → Create Database → REST API)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your-tmdb-api-key
